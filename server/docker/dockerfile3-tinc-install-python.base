FROM tinc-install-jre:latest

# Install cert receiver
RUN apt-get install -y -o Acquire::Retries=300 \
    python3 python3-pip python3-venv

# Configure venv
RUN python3 -m venv /home/root/.venv
ENV PATH /home/root/.venv/bin:$PATH

# Install cert receiver
RUN pip3 install uploadserver==6.0.1 --retries 300
